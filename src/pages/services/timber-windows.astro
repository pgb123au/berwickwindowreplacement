---
import Layout from '../../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "When is a timber window the right choice over aluminium in Berwick?",
      "acceptedAnswer": { "@type": "Answer", "text": "Two main cases. (1) Heritage and period-style homes — old-Berwick cottages, Victorian or Edwardian weatherboards, Federation brick — where the original windows were timber sash and a like-for-like replacement keeps the streetscape look right. Council planning generally prefers it for properties with a heritage overlay. (2) Premium new builds and architect-designed homes where the warm look of solid timber inside is a deliberate design call — usually paired with double-glazed IGUs for performance. Outside those two cases, aluminium is the practical choice for Casey." }
    },
    {
      "@type": "Question",
      "name": "What does a timber window cost in Berwick?",
      "acceptedAnswer": { "@type": "Answer", "text": "Solid timber windows run roughly 60–100% more than aluminium equivalents: $800–$2,400 per window installed. A heritage sash window with paint-grade primed finish lands at $1,200–$1,800. A premium-spec double-glazed casement with stained finish closer to $2,000–$2,400. Bifold and stacker timber doors run $8,000–$15,000 for typical 3–4m openings. Includes supply (Stegbar Timber or Trend Timber), install, perimeter sealing, architrave patch-back; painting and final stain is by your painter." }
    },
    {
      "@type": "Question",
      "name": "How much maintenance does a timber window need?",
      "acceptedAnswer": { "@type": "Answer", "text": "Painted exterior timber needs a repaint every 8–12 years in Berwick's climate — sooner on north and west elevations (UV), longer on south. Internal painted finish lasts 15–20 years. Modern timber windows have factory-applied primer and one or two topcoats, plus an internal aluminium cladding strip available on premium specs which removes most of the maintenance burden. A clear-finished (stained) external timber will need a re-coat every 5–7 years. We point owners towards the alu-clad option if they want timber-look interior with low-maintenance exterior." }
    },
    {
      "@type": "Question",
      "name": "Can timber windows be double-glazed?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — double-glazing is standard on premium timber from Stegbar and Trend, and we'd recommend it for any new timber install in Berwick. Timber is a far better thermal frame than standard aluminium to begin with (low conductivity), and combined with double-glazed IGUs you get U-values of 1.8–2.5, comfortably better than even thermally broken aluminium. The premium over single-glaze timber is typically $400–$600 per window — proportionally smaller than the aluminium uplift because the frame is the bigger share of the cost." }
    },
    {
      "@type": "Question",
      "name": "Do you do heritage-match sash windows for old Berwick cottages?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The original Berwick township homes around High Street and the older streets near the railway have timber sash windows with characteristic mouldings (typically a 2-over-2 or 6-over-1 pane configuration with a horns sash detail). Stegbar Timber and Trend Timber both make modern equivalents that match those profiles closely — same external proportions, same glazing-bar pattern, but with modern weather seals and double-glazing optional. Council planning is generally supportive of like-for-like replacement on heritage overlay properties when the profile matches." }
    },
    {
      "@type": "Question",
      "name": "Solid timber vs alu-clad timber — what's the difference?",
      "acceptedAnswer": { "@type": "Answer", "text": "Solid timber: timber inside and out, painted or stained finish on both faces. The warmest, most traditional look. Repaint exterior every 8–12 years. Alu-clad timber: timber on the inside (you see the warm timber finish from the room), powder-coated aluminium skin on the outside (you see modern aluminium from the street). Best of both — timber-look interior, near-zero maintenance exterior, no repainting required. Premium of $200–$400 per window over solid timber, well worth it for owners who want the look but not the repaint cycle." }
    }
  ]
};
---
<Layout
  title="Timber Windows Berwick | Heritage Match & Premium New Build | (03) 9003 0108"
  description="Solid timber sash and casement window replacement in Berwick, Cranbourne, Narre Warren. Stegbar Timber & Trend Timber, heritage-match cottage windows, double-glaze upgrades, alu-clad available."
  canonical="https://berwickwindowreplacement.com.au/services/timber-windows/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">Heritage match &amp; premium new build</span>
      <h1>Timber windows in <span class="accent">Berwick &amp; Casey</span>.</h1>
      <p class="hero-sub">
        Solid timber sash and casement windows for heritage cottages and
        period-style homes, and premium double-glazed timber for high-end
        new builds where the warm interior look is part of the design. Stegbar
        Timber and Trend Timber, alu-clad options available.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Book a free measure</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <h2>When timber is the right call.</h2>
      <div style="max-width: 65rem;">
        <h3>1. Heritage cottages &amp; period-style homes.</h3>
        <p>
          Original Berwick township homes around High Street, Wilson Botanic
          Park and the older streets running off the rail line have timber sash
          windows from the late 1800s and early 1900s. A modern aluminium
          replacement looks wrong on that streetscape, and council planning
          generally prefers a like-for-like timber replacement on heritage
          overlay properties. Modern Stegbar Timber and Trend Timber sash
          windows match the original profiles closely while including modern
          weather seals and an optional double-glazed IGU.
        </p>

        <h3 style="margin-top: 2rem;">2. Premium new builds &amp; architect-designed.</h3>
        <p>
          High-end new builds &mdash; particularly in the Berwick foothills
          and acreage blocks near Wilson Botanic Park &mdash; often spec
          timber windows as a deliberate interior design choice. Solid timber
          inside paired with double-glazing reads as a warmer, more crafted
          finish than aluminium. Typically these jobs run $25K&ndash;$60K
          across the whole house, with bifold or stacker timber doors at
          the rear running another $10K&ndash;$20K each.
        </p>

        <h3 style="margin-top: 2rem;">3. Like-for-like in 1970s timber-frame homes.</h3>
        <p>
          Some 1960s&ndash;70s Endeavour Hills and Doveton homes were built
          with timber-frame windows originally. Replacing them with timber
          rather than swapping to aluminium keeps the architrave depths
          and sill profiles consistent with what&rsquo;s already there
          &mdash; aluminium would look slim and modern next to the
          house&rsquo;s existing detail.
        </p>

        <h3 style="margin-top: 2rem;">Solid timber vs alu-clad timber.</h3>
        <ul>
          <li><strong>Solid timber:</strong> Timber inside and out, painted or stained both faces. Most traditional. Repaint exterior every 8&ndash;12 years. ~$800&ndash;$2,000/window installed.</li>
          <li><strong>Alu-clad timber:</strong> Timber inside, powder-coated aluminium on the exterior face. Timber look from the room, low-maintenance from the street. No exterior repainting. Premium ~$200&ndash;$400/window over solid timber.</li>
        </ul>

        <h3 style="margin-top: 2rem;">Double-glazing on timber windows.</h3>
        <p>
          Modern timber windows are commonly specced with a double-glazed
          IGU (insulated glass unit) sealed into the timber frame. Combined
          with timber&rsquo;s naturally low thermal conductivity you get
          U-values of 1.8&ndash;2.5, better than thermally broken aluminium
          and well below standard single-glaze (6&ndash;7). The premium for
          double-glazed timber is $400&ndash;$600 per window over single
          &mdash; proportionally smaller than the aluminium uplift.
        </p>

        <h3 style="margin-top: 2rem;">Maintenance reality.</h3>
        <ul>
          <li><strong>Painted external timber:</strong> Repaint every 8&ndash;12 years. North and west elevations sooner.</li>
          <li><strong>Stained external timber:</strong> Re-coat every 5&ndash;7 years &mdash; UV is harder on stain than paint.</li>
          <li><strong>Alu-clad external:</strong> Hose down occasionally. No painting.</li>
          <li><strong>Internal:</strong> Paint or stain lasts 15&ndash;20 years before refresh.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="section-inner">
      <h2>Where we install timber windows.</h2>
      <div class="areas-grid">
        <a class="area-pill" href="/berwick/">Berwick</a>
        <a class="area-pill" href="/cranbourne/">Cranbourne</a>
        <a class="area-pill" href="/narre-warren/">Narre Warren</a>
        <a class="area-pill" href="/hampton-park/">Hampton Park</a>
        <a class="area-pill" href="/endeavour-hills/">Endeavour Hills</a>
        <a class="area-pill" href="/city-of-casey/">All City of Casey</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free timber window measure-up.</h2>
        <p>Heritage profile match, alu-clad vs solid, double-glaze priced both ways.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
